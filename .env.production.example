NODE_ENV=production

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# API
API_PORT=4000
APP_ORIGIN=https://your-frontend-domain.com
COOKIE_DOMAIN=your-frontend-domain.com
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
STORAGE_ROOT=/data/payroll-storage
MFA_ISSUER=Profacc

# Frontend
NEXT_PUBLIC_API_URL=https://your-frontend-domain.com/api
API_INTERNAL_URL=https://your-backend-domain.com/api
