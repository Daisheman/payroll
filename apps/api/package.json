{
  "name": "@payroll/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "cd ../.. && npm --workspace packages/schemas run build",
    "start": "node dist/src/main.js",
    "start:dev": "npm run build && npm run start:local",
    "start:local": "node dist/src/main.js",
    "build": "node ../../node_modules/@nestjs/cli/bin/nest.js build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "prisma:seed": "node ../../node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@payroll/schemas": "file:../../packages/schemas",
    "@prisma/client": "^6.8.2",
    "argon2": "^0.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.1",
    "prisma": "^6.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.19.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.19",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.9",
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
